  "orchestratorAgentTest": {
    "description": "Test payload for Orchestrator Agent Lambda (main endpoint)",
    "endpoint": "POST /farm-advisor",
    "payload": {
      "body": "{\"farmerName\":\"Rajesh Kumar\",\"location\":\"Nashik, Maharashtra India\",\"farmSize\":5,\"crop\":\"grapes\",\"fertilizerType\":\"organic\",\"irrigationMethod\":\"drip\",\"pesticideUsage\":\"low\",\"expectedYield\":125}"
    },
    "expectedResponse": {
      "farmerName": "string",
      "summary": "string",
      "urgentAlerts": "array",
      "weatherInsights": "object",
      "marketInsights": "object",
      "sustainabilityRecommendations": "array",
      "totalPotentialSavings": "number",
      "totalCarbonReduction": "number",
      "prioritizedActionPlan": "array",
      "cached": "boolean",
      "agentsUsed": "array",
      "timestamp": "string"
    }
  },
  
  "validationTests": {
    "description": "Test payloads for input validation",
    "weatherAgentInvalid": {
      "body": "{\"location\":\"Nashik\",\"crop\":\"grapes\"}"
    },
    "expectedError": {
      "statusCode": 400,
      "error": "Invalid input",
      "details": ["farmSize is required and must be a positive number", "irrigationType is required and must be a string"]
    }
  },
  
  "additionalTestCases": {
    "weatherAgent_Mumbai": {
      "body": "{\"location\":\"Mumbai, Maharashtra India\",\"crop\":\"rice\",\"farmSize\":10,\"irrigationType\":\"flood\"}"
    },
    "weatherAgent_Delhi": {
      "body": "{\"location\":\"Delhi, India\",\"crop\":\"wheat\",\"farmSize\":15,\"irrigationType\":\"sprinkler\"}"
