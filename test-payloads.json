{
  "weatherAgentTest": {
    "description": "Test payload for Weather Agent Lambda",
    "endpoint": "POST /weather-context",
    "payload": {
      "body": "{\"location\":\"Nashik, Maharashtra India\",\"crop\":\"grapes\",\"farmSize\":5,\"irrigationType\":\"drip\"}"
    },
    "expectedResponse": {
