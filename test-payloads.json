        "temperature": "number",
        "humidity": "number",
        "rainfall": "number",
        "condition": "string"
      },
      "forecast7Days": "array",
      "alerts": "array",
      "farmingAdvice": {
        "irrigationRecommendation": "string",
        "pestRisk": "string",
        "harvestWindow": "string",
        "carbonImpact": "string"
      },
      "cached": "boolean"
    }
  },
  
